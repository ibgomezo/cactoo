{
  "name": "cactoo",
  "version": "0.0.1",
  "private": true,
  "imports": {
    "#core/models": "./core/models.js",
    "#core/logger": "./core/logger.js",
    "#core/commons/*": "./core/commons/*.js",
    "#core/tests/*": "./core/tests/*.js",
    "#modules/*": "./src/modules/*.js",
    "#src/*": "./src/*.js"
  },
  "scripts": {
    "start": "dotenv -c '.env' -- node index.js",
    "dev": "dotenv -c '.env' -- nodemon index.js",
    "pretest": "NODE_ENV=test dotenv -c '.env' -- node core/tests/pre-test.js",
    "test": "NODE_ENV=test dotenv -c '.env' -- node --test --test-reporter=spec",
    "migrations": "dotenv -c '.env' -- ./node_modules/.bin/sequelize db:migrate",
    "seeds": "dotenv -c '.env' -- ./node_modules/.bin/sequelize db:seed:all"
  },
  "dependencies": {
    "connect": "^3.7.0",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "debug": "~2.6.9",
    "ejs": "^6.0.1",
    "express": "~4.16.1",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.17.3",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@stylistic/eslint-plugin-js": "^4.2.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.26.0",
    "eslint-plugin-n": "^17.17.0",
    "globals": "^16.1.0",
    "nodemon": "^3.1.10",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.1.1"
  }
}
