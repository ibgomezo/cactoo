PORT=4000
DB_URL=postgres://user:password@localhost:5432/myapp
DB_URL_TEST=postgres://user:password@localhost:5432/myapp_test
COOKIE_SECRET=change-me-in-production

# Optional: comma-separated allowed origins for CORS in production
# CORS_ORIGINS=https://myapp.com,https://www.myapp.com

# Optional: HyperDX observability (omit to disable)
# HYPERDX_API_KEY=
# HYPERDX_SERVICE_NAME=my-app
# HYPERDX_DISABLED_INSTRUMENTATIONS=pg,express,http
